{
  "name": "easymc-server-agent",
  "version": "1.0.0",
  "description": "AI-powered Minecraft server management tool with Agent capabilities",
  "main": "start.js",
  "scripts": {
    "start": "node start.js",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"cd client && npm run dev\"",
    "build": "cd client && npm run build",
    "postinstall": "cd client && npm install"
  },
  "keywords": [
    "minecraft",
    "server",
    "agent",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "extract-zip": "^2.0.1",
    "fast-xml-parser": "^4.5.0",
    "iconv-lite": "^0.7.3",
    "js-yaml": "^4.1.0",
    "openai": "^4.70.0",
    "socket.io": "^4.8.0",
    "tar": "^7.4.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
